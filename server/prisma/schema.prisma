generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DOCTOR
  NURSE
  RECEPTION
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  role         Role     @default(RECEPTION)
  createdAt    DateTime @default(now())

  appointmentEvents AppointmentEvent[]
}

model Patient {
  id               Int       @id @default(autoincrement())
  name             String
  age              Int
  contact          String
  email            String
  address          String
  gender           String
  bloodType        String?
  allergies        String?
  emergencyContact String?
  medicalHistory   String?
  primaryCondition String?
  assignedDoctor   String?
  followUpDue      DateTime?
  lastVisit        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  visits           ClinicalVisit[]
  appointments     Appointment[]

  appointmentRequests         AppointmentRequest[]
  appointmentRescheduleRequests AppointmentRescheduleRequest[]

  @@index([email])
  @@index([name])
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
}

model Doctor {
  id               Int       @id @default(autoincrement())
  name             String
  specialization   String
  availableDays   String[]
  description      String?
  yearsExperience  Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([name])
}

model Staff {
  id             Int          @id @default(autoincrement())
  name           String
  role           String
  department    String
  contactNumber String
  status         StaffStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([department])
  @@index([name])
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentRequestStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum AppointmentRescheduleRequestStatus {
  PENDING
  FULFILLED
  CANCELLED
}

enum AppointmentEventType {
  CREATED
  CONFIRMED
  CANCELLED
  RESCHEDULE_REQUESTED
  RESCHEDULED
  COMPLETED
  NO_SHOW
}

model Appointment {
  id         Int               @id @default(autoincrement())
  patientId  Int
  patient    Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorName String
  startAt    DateTime
  endAt      DateTime?
  status     AppointmentStatus @default(SCHEDULED)
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt DateTime         @updatedAt

  events   AppointmentEvent[]
  requests AppointmentRequest[]
  rescheduleRequests AppointmentRescheduleRequest[]

  @@index([patientId])
  @@index([startAt])
  @@index([status])
}

model AppointmentRequest {
  id        Int                     @id @default(autoincrement())
  patientId Int
  patient   Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)

  weekStart DateTime
  weekEnd   DateTime

  status    AppointmentRequestStatus @default(PENDING)

  // The appointment created after admin fulfills the request.
  fulfilledAppointmentId Int?
  fulfilledAppointment   Appointment? @relation(fields: [fulfilledAppointmentId], references: [id], onDelete: SetNull)

  // Useful for inbound flows where we only have the phone number initially.
  requesterContact String?
  message          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentRescheduleRequest {
  id         Int                                  @id @default(autoincrement())
  patientId  Int
  patient    Patient                              @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId Int?
  appointment   Appointment?                      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  status            AppointmentRescheduleRequestStatus @default(PENDING)

  // Admin will pick a new slot; store requested context here.
  message           String?
  requesterContact  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentEvent {
  id            Int              @id @default(autoincrement())
  appointmentId Int
  appointment   Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  type   AppointmentEventType
  notes  String?

  // Who initiated the change (admin/doctor/reception). For inbound flows, this can stay null.
  actorUserId Int?
  actorUser   User?            @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
}

model ClinicalVisit {
  id               Int      @id @default(autoincrement())
  patientId        Int
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitDate        DateTime
  chiefComplaint   String
  diagnosis        String?
  clinicalNotes    String?
  providerLabel    String?
  createdAt        DateTime @default(now())

  @@index([patientId])
  @@index([visitDate])
}
